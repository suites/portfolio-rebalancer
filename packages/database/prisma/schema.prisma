  safeReasonCode                 String   @default("AUTHORIZATION_NOT_DISPATCHED") @map("safe_reason_code")
  authorizationPreparationDigest String   @default(dbgenerated()) @map("authorization_preparation_digest") @db.Char(64)
  authorizedRequestDigest        String   @default(dbgenerated()) @map("authorized_request_digest") @db.Char(64)
  canonicalProof                 String   @default(dbgenerated()) @map("canonical_proof") @db.Text
  proofSha256                    String   @default(dbgenerated()) @map("proof_sha256") @db.Char(64)
  recordedAt                     DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)
  createdAt                      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  submissionAuthorization OrderSubmissionAuthorization @relation(fields: [submissionAuthorizationId], references: [id], onDelete: Restrict)
  order                   OrderLedger                  @relation(fields: [orderId], references: [id], onDelete: Restrict)
  stateHistory            OrderStateHistory?

  @@index([recordedAt(sort: Desc)])
  @@map("order_non_dispatch_evidence")
}

model OrderPreAuthorizationNonDispatchEvidence {
  id                 String   @id @default(uuid()) @db.Uuid
  orderId            String   @unique(map: "order_pre_auth_non_dispatch_evidence_order_id_key") @map("order_id") @db.Uuid
  reservationId      String   @unique(map: "order_pre_auth_non_dispatch_evidence_reservation_id_key") @map("reservation_id") @db.Uuid
  logicalOrderId     String   @unique(map: "order_pre_auth_non_dispatch_evidence_logical_order_id_key") @default(dbgenerated()) @map("logical_order_id") @db.Uuid
  actor              String
  safeReasonCode     String   @default("PRE_AUTHORIZATION_NOT_COMPLETED") @map("safe_reason_code")
  reservedGrossMinor BigInt   @default(dbgenerated()) @map("reserved_gross_minor")
  canonicalProof     String   @default(dbgenerated()) @map("canonical_proof") @db.Text
  proofSha256        String   @default(dbgenerated()) @map("proof_sha256") @db.Char(64)
  recordedAt         DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order        OrderLedger           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  reservation  DailyTradeReservation @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  stateHistory OrderStateHistory?

  @@index([recordedAt(sort: Desc)])
  @@map("order_pre_auth_non_dispatch_evidence")
}

model CancelOperatorAuthorization {
  id                     String    @id @default(uuid()) @db.Uuid
  orderId                String    @map("order_id") @db.Uuid
  authorizationId        String    @unique(map: "cancel_operator_authorization_authorization_id_key") @map("authorization_id")
  actor                  String
  action                 String
  confirmationVersion    String    @map("confirmation_version")
  canonicalContent       String    @map("canonical_content") @db.Text
  canonicalRequestDigest String    @map("canonical_request_digest") @db.Char(64)
  authorizationDigest    String    @unique(map: "cancel_operator_authorization_digest_key") @map("authorization_digest") @db.Char(64)
  authorizedAt           DateTime  @map("authorized_at") @db.Timestamptz(6)
  expiresAt              DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt             DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  order         OrderLedger               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  dispatchClaim OrderCancelDispatchClaim?

  @@index([orderId, expiresAt])
  @@map("cancel_operator_authorization")
}

model OrderCancelDispatchClaim {
  id                            String           @id @default(uuid()) @db.Uuid
  cancelOperatorAuthorizationId String           @unique(map: "order_cancel_dispatch_claim_operator_authorization_id_key") @map("cancel_operator_authorization_id") @db.Uuid
  orderId                       String           @unique(map: "order_cancel_dispatch_claim_order_id_key") @map("order_id") @db.Uuid
  authorizationId               String           @unique(map: "order_cancel_dispatch_claim_authorization_id_key") @map("authorization_id")
  planId                        String           @map("plan_id") @db.Uuid
  planVersion                   Int              @map("plan_version")
  planOrderId                   String           @map("plan_order_id") @db.Uuid
  logicalOrderId                String           @map("logical_order_id") @db.Uuid
  canonicalRequest              String           @map("canonical_request") @db.Text
  claimEnvelopeDigest           String           @map("claim_envelope_digest") @db.Char(64)
  authorizedRequestDigest       String           @map("authorized_request_digest") @db.Char(64)
  clientOrderId                 String           @map("client_order_id") @db.Char(36)
  brokerAccountReferenceHmac    String           @map("broker_account_reference_hmac") @db.Char(64)
  brokerOrderId                 String           @map("broker_order_id")
  ledgerState                   OrderLedgerState @map("ledger_state")
  operatorAuthorizationDigest   String           @map("operator_authorization_digest") @db.Char(64)
  authorizationIssuedAt         DateTime         @map("authorization_issued_at") @db.Timestamptz(6)
  authorizationExpiresAt        DateTime         @map("authorization_expires_at") @db.Timestamptz(6)
  claimedAt                     DateTime         @default(now()) @map("claimed_at") @db.Timestamptz(6)
  intentAuditedAt               DateTime         @map("intent_audited_at") @db.Timestamptz(6)
  dispatchStartedAt             DateTime         @map("dispatch_started_at") @db.Timestamptz(6)

  cancelOperatorAuthorization CancelOperatorAuthorization  @relation(fields: [cancelOperatorAuthorizationId], references: [id], onDelete: Restrict)
  order                       OrderLedger                  @relation(fields: [orderId], references: [id], onDelete: Restrict)
  brokerAction                BrokerOrderAction?
  brokerEvidence              BrokerOrderResponseEvidence?

  @@index([orderId, claimedAt(sort: Desc)])
  @@index([planId, planVersion, planOrderId])
  @@index([authorizationExpiresAt])
  @@map("order_cancel_dispatch_claim")
}

model ManualOrderApproval {
  id                  String    @id @default(uuid()) @db.Uuid
  planOrderId         String    @map("plan_order_id") @db.Uuid
  accountId           String    @map("account_id") @db.Uuid
  approvalHash        String    @unique(map: "manual_order_approval_hash_key") @map("approval_hash") @db.Char(64)
  planHash            String    @map("plan_hash") @db.Char(64)
  actor               String
  confirmationVersion String    @map("confirmation_version")
  canonicalContent    String    @map("canonical_content") @db.Text
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  consumedAt          DateTime? @map("consumed_at") @db.Timestamptz(6)
  consumedByOrderId   String?   @unique(map: "manual_order_approval_consumed_by_order_id_key") @map("consumed_by_order_id") @db.Uuid

  planOrder               RebalancePlanOrder            @relation(fields: [planOrderId], references: [id], onDelete: Restrict)
  account                 BrokerAccount                 @relation(fields: [accountId], references: [id], onDelete: Restrict)
  consumedByOrder         OrderLedger?                  @relation("ConsumedApprovalOrder", fields: [consumedByOrderId], references: [id], onDelete: Restrict)
  stateHistory            OrderStateHistory[]
  submissionAuthorization OrderSubmissionAuthorization?

  @@index([planOrderId, expiresAt])
  @@index([accountId, expiresAt])
  @@map("manual_order_approval")
}

model KillSwitchEvent {
  id         String          @id @default(uuid()) @db.Uuid
  accountId  String          @map("account_id") @db.Uuid
  version    Int
  state      KillSwitchState
  reason     String
  actor      String
  occurredAt DateTime        @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  account BrokerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([accountId, version], map: "kill_switch_event_account_version_key")
  @@index([accountId, occurredAt(sort: Desc)])
  @@map("kill_switch_event")
}
