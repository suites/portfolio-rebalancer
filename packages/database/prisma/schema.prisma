generator client {
  provider     = "prisma-client"
  output       = "../generated/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TargetConfigStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum CollectionRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum SnapshotValidationStatus {
  VERIFIED
  BLOCKED
}

enum CheckOutcome {
  PASSED
  BLOCKED
}

enum BrokerRequestOutcome {
  SUCCEEDED
  HTTP_ERROR
  TIMEOUT
  NETWORK_ERROR
  SCHEMA_ERROR
}

enum BrokerResponseValidationOutcome {
  PASSED
  SCHEMA_ERROR
}

enum RebalanceMode {
  SHADOW
  PAPER
  LIVE
}

enum RebalanceRunStatus {
  RUNNING
  NO_ACTION
  PLANNED
  BLOCKED
  FAILED
}

enum RebalancePlanStatus {
  NO_ACTION
  PLANNED
  BLOCKED
}

enum OrderLedgerState {
  PLANNED
  SUBMITTING
  PENDING
  PARTIAL_FILLED
  FILLED
  CANCELED
  REJECTED
  UNKNOWN
  UNKNOWN_BLOCKED
}

enum KillSwitchState {
  ENGAGED
  DISENGAGED
}

enum BrokerOrderActionKind {
  CANCEL
  REPLACE
}

enum BrokerOrderEvidenceKind {
  SUBMIT
  RECONCILE
  CANCEL_ATTEMPT
  REPLACE_ATTEMPT
}

enum LivePromotionState {
  REVOKED
  GRANTED
}

model BrokerAccount {
  id              String   @id @default(uuid()) @db.Uuid
  broker          String
  externalRefHmac String   @map("external_ref_hmac") @db.Char(64)
  maskedNumber    String   @map("masked_number")
  accountTypeRaw  String   @map("account_type_raw")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt      DateTime @map("last_seen_at") @db.Timestamptz(6)

  targetConfig      TargetConfig?
  collectionRuns    CollectionRun[]
  snapshots         PortfolioSnapshot[]
  rebalanceRuns     RebalanceRun[]
  ledgerOrders      OrderLedger[]
  tradeLimits       DailyTradeLimit[]
  approvals         ManualOrderApproval[]
  killSwitches      KillSwitchEvent[]
  livePromotions    LivePromotionEvent[]
  riskEvidence      ExecutionRiskEvidence[]
  preSubmitEvidence PreSubmitEvidence[]
  operationalConfig OperationalConfig?

  @@unique([broker, externalRefHmac])
  @@map("broker_account")
}

model TargetConfig {
  id        String   @id @default(uuid()) @db.Uuid
  accountId String   @unique @map("account_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  account  BrokerAccount         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  versions TargetConfigVersion[]

  @@map("target_config")
}

model TargetConfigVersion {
  id          String             @id @default(uuid()) @db.Uuid
  configId    String             @map("config_id") @db.Uuid
  version     Int
  status      TargetConfigStatus @default(DRAFT)
  contentHash String             @map("content_hash") @db.Char(64)
  appVersion  String             @map("app_version")
  source      Json               @db.JsonB
  cashPolicy  Json               @map("cash_policy") @db.JsonB
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  config                TargetConfig           @relation(fields: [configId], references: [id], onDelete: Restrict)
  allocations           TargetAllocation[]
  snapshots             PortfolioSnapshot[]
  rebalanceRuns         RebalanceRun[]
  rebalancePlans        RebalancePlan[]
  rebalancePlanVersions RebalancePlanVersion[]

  @@unique([configId, version])
  @@unique([configId, contentHash])
  @@map("target_config_version")
}

model TargetAllocation {
  id                String @id @default(uuid()) @db.Uuid
  configVersionId   String @map("config_version_id") @db.Uuid
  assetKey          String @map("asset_key")
  label             String
  targetBasisPoints Int    @map("target_basis_points")
  lowerBasisPoints  Int    @map("lower_basis_points")
  upperBasisPoints  Int    @map("upper_basis_points")
  bandPolicy        Json   @map("band_policy") @db.JsonB
  compositionPolicy Json   @map("composition_policy") @db.JsonB

  configVersion TargetConfigVersion @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  instruments   TargetInstrument[]

  @@unique([configVersionId, assetKey])
  @@unique([id, configVersionId], map: "target_allocation_id_config_version_id_key")
  @@map("target_allocation")
}

model TargetInstrument {
  id                String  @id @default(uuid()) @db.Uuid
  allocationId      String  @map("allocation_id") @db.Uuid
  configVersionId   String  @map("config_version_id") @db.Uuid
  validationId      String? @map("validation_id") @db.Uuid
  marketCountry     String  @map("market")
  listingMarket     String? @map("listing_market")
  symbol            String
  name              String
  englishName       String? @map("english_name")
  currency          String
  withinAssetPoints Int     @map("within_asset_points")

  allocation TargetAllocation      @relation(fields: [allocationId, configVersionId], references: [id, configVersionId], onDelete: Restrict)
  validation InstrumentValidation? @relation(fields: [validationId, marketCountry, symbol], references: [id, marketCountry, symbol], onDelete: Restrict)

  @@unique([allocationId, marketCountry, symbol], map: "target_instrument_allocation_id_market_symbol_key")
  @@unique([configVersionId, marketCountry, symbol], map: "target_instrument_config_version_id_market_symbol_key")
  @@index([validationId])
  @@map("target_instrument")
}

model InstrumentCatalog {
  id               String   @id @default(uuid()) @db.Uuid
  broker           String
  marketCountry    String   @map("market_country")
  symbol           String
  listingMarket    String   @map("listing_market")
  name             String
  englishName      String?  @map("english_name")
  isinCode         String   @map("isin_code")
  currency         String
  securityType     String   @map("security_type")
  listingStatus    String   @map("listing_status")
  lastValidationId String?  @unique @map("last_validation_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  validations    InstrumentValidation[] @relation("InstrumentCatalogValidations")
  lastValidation InstrumentValidation?  @relation("InstrumentCatalogLastValidation", fields: [lastValidationId], references: [id], onDelete: Restrict)

  @@unique([broker, marketCountry, symbol])
  @@index([name])
  @@index([englishName])
  @@map("instrument_catalog")
}

model InstrumentValidation {
  id                        String   @id @default(uuid()) @db.Uuid
  catalogId                 String   @map("catalog_id") @db.Uuid
  requestedMarketCountry    String   @map("requested_market_country")
  requestedSymbol           String   @map("requested_symbol")
  providerApiVersion        String   @map("provider_api_version")
  marketCountry             String   @map("market_country")
  symbol                    String
  listingMarket             String   @map("listing_market")
  name                      String
  englishName               String?  @map("english_name")
  isinCode                  String   @map("isin_code")
  currency                  String
  securityType              String   @map("security_type")
  isCommonShare             Boolean  @map("is_common_share")
  listingStatus             String   @map("listing_status")
  listDate                  String?  @map("list_date")
  delistDate                String?  @map("delist_date")
  sharesOutstanding         String   @map("shares_outstanding")
  leverageFactor            String?  @map("leverage_factor")
  liquidationTrading        Boolean? @map("liquidation_trading")
  nxtSupported              Boolean? @map("nxt_supported")
  krxTradingSuspended       Boolean? @map("krx_trading_suspended")
  nxtTradingSuspended       Boolean? @map("nxt_trading_suspended")
  targetEligibility         String   @map("target_eligibility")
  targetReasonCodes         Json     @map("target_reason_codes") @db.JsonB
  tradeBlockedNow           Boolean  @map("trade_blocked_now")
  tradeReasonCodes          Json     @map("trade_reason_codes") @db.JsonB
  requiresOrderRevalidation Boolean  @map("requires_order_revalidation")
  stockPayload              Json     @map("stock_payload") @db.JsonB
  warningsPayload           Json     @map("warnings_payload") @db.JsonB
  stockPayloadSha256        String   @map("stock_payload_sha256") @db.Char(64)
  warningsPayloadSha256     String   @map("warnings_payload_sha256") @db.Char(64)
  observedAt                DateTime @map("observed_at") @db.Timestamptz(6)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  catalog           InstrumentCatalog  @relation("InstrumentCatalogValidations", fields: [catalogId], references: [id], onDelete: Restrict)
  currentForCatalog InstrumentCatalog? @relation("InstrumentCatalogLastValidation")
  targetInstruments TargetInstrument[]

  @@unique([id, marketCountry, symbol], map: "instrument_validation_id_market_country_symbol_key")
  @@index([marketCountry, symbol, observedAt(sort: Desc)])
  @@map("instrument_validation")
}

model CollectionRun {
  id             String              @id @default(uuid()) @db.Uuid
  accountId      String              @map("account_id") @db.Uuid
  status         CollectionRunStatus @default(RUNNING)
  startedAt      DateTime            @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime?           @map("completed_at") @db.Timestamptz(6)
  appVersion     String              @map("app_version")
  adapterVersion String              @map("adapter_version")
  errorCode      String?             @map("error_code")

  account         BrokerAccount          @relation(fields: [accountId], references: [id], onDelete: Restrict)
  rawResponses    RawBrokerResponse[]
  requestAttempts BrokerRequestAttempt[]
  snapshot        PortfolioSnapshot?

  @@index([accountId, startedAt(sort: Desc)])
  @@map("collection_run")
}

model RawBrokerResponse {
  id               String   @id @default(uuid()) @db.Uuid
  collectionRunId  String   @map("collection_run_id") @db.Uuid
  operationId      String   @map("operation_id")
  ordinal          Int
  requestId        String?  @map("request_id")
  httpStatus       Int      @map("http_status")
  receivedAt       DateTime @map("received_at") @db.Timestamptz(6)
  redactedBody     Json     @map("redacted_body") @db.JsonB
  bodySha256       String   @map("body_sha256") @db.Char(64)
  redactionVersion String   @map("redaction_version")

  collectionRun CollectionRun @relation(fields: [collectionRunId], references: [id], onDelete: Restrict)

  @@unique([collectionRunId, operationId, ordinal])
  @@index([requestId])
  @@map("raw_broker_response")
}

model BrokerRequestAttempt {
  id                     String               @id @default(uuid()) @db.Uuid
  workflowType           String               @map("workflow_type")
  correlationId          String               @map("correlation_id") @db.Uuid
  collectionRunId        String?              @map("collection_run_id") @db.Uuid
  operationId            String               @map("operation_id")
  ordinal                Int
  attempt                Int
  rateLimitGroup         String               @map("rate_limit_group")
  startedAt              DateTime             @map("started_at") @db.Timestamptz(6)
  completedAt            DateTime             @map("completed_at") @db.Timestamptz(6)
  outcome                BrokerRequestOutcome
  httpStatus             Int?                 @map("http_status")
  requestId              String?              @map("request_id")
  rateLimitLimit         Int?                 @map("rate_limit_limit")
  rateLimitRemaining     Int?                 @map("rate_limit_remaining")
  rateLimitResetSeconds  Int?                 @map("rate_limit_reset_seconds")
  retryAfterSeconds      Int?                 @map("retry_after_seconds")
  safeErrorCode          String?              @map("safe_error_code")
  redactedRequestSummary Json                 @map("redacted_request_summary") @db.JsonB
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  collectionRun           CollectionRun?            @relation(fields: [collectionRunId], references: [id], onDelete: Restrict)
  responseValidation      BrokerResponseValidation?
  priceSnapshots          PriceSnapshot[]
  marketCalendarSnapshots MarketCalendarSnapshot[]

  @@unique([workflowType, correlationId, operationId, ordinal, attempt], map: "broker_request_attempt_identity_key")
  @@index([correlationId, startedAt(sort: Desc)])
  @@index([collectionRunId, startedAt])
  @@index([requestId])
  @@map("broker_request_attempt")
}

model BrokerResponseValidation {
  id               String                          @id @default(uuid()) @db.Uuid
  requestAttemptId String                          @unique(map: "broker_response_validation_request_attempt_id_key") @map("request_attempt_id") @db.Uuid
  operationId      String                          @map("operation_id")
  outcome          BrokerResponseValidationOutcome
  redactedBody     Json                            @map("redacted_body") @db.JsonB
  bodySha256       String                          @map("body_sha256") @db.Char(64)
  safeErrorCode    String?                         @map("safe_error_code")
  validatedAt      DateTime                        @map("validated_at") @db.Timestamptz(6)

  requestAttempt            BrokerRequestAttempt @relation(fields: [requestAttemptId], references: [id], onDelete: Restrict)
  accountPreSubmitEvidence  PreSubmitEvidence[]  @relation("PreSubmitAccountValidation")
  quotePreSubmitEvidence    PreSubmitEvidence[]  @relation("PreSubmitQuoteValidation")
  priceLimitSubmitEvidence  PreSubmitEvidence[]  @relation("PreSubmitPriceLimitValidation")
  calendarPreSubmitEvidence PreSubmitEvidence[]  @relation("PreSubmitCalendarValidation")
  capacityPreSubmitEvidence PreSubmitEvidence[]  @relation("PreSubmitCapacityValidation")
  instrumentSubmitEvidence  PreSubmitEvidence[]  @relation("PreSubmitInstrumentValidation")
  warningsPreSubmitEvidence PreSubmitEvidence[]  @relation("PreSubmitWarningsValidation")
  openOrdersSubmitEvidence  PreSubmitEvidence[]  @relation("PreSubmitOpenOrdersValidation")

  @@map("broker_response_validation")
}

model PortfolioSnapshot {
  id                    String                   @id @default(uuid()) @db.Uuid
  collectionRunId       String                   @unique @map("collection_run_id") @db.Uuid
  accountId             String                   @map("account_id") @db.Uuid
  targetConfigVersionId String?                  @map("target_config_version_id") @db.Uuid
  observedAt            DateTime                 @map("observed_at") @db.Timestamptz(6)
  persistedAt           DateTime                 @default(now()) @map("persisted_at") @db.Timestamptz(6)
  validationStatus      SnapshotValidationStatus @map("validation_status")
  baseCurrency          String                   @map("base_currency")
  managedCashMinor      BigInt?                  @map("managed_cash_minor")
  securitiesValueMinor  BigInt                   @map("securities_value_minor")
  totalValueMinor       BigInt                   @map("total_value_minor")
  usdKrwRate            String?                  @map("usd_krw_rate")
  digest                String                   @db.Char(64)

  collectionRun         CollectionRun            @relation(fields: [collectionRunId], references: [id], onDelete: Restrict)
  account               BrokerAccount            @relation(fields: [accountId], references: [id], onDelete: Restrict)
  targetConfigVersion   TargetConfigVersion?     @relation(fields: [targetConfigVersionId], references: [id], onDelete: Restrict)
  holdings              HoldingSnapshot[]
  buyingPower           BuyingPowerSnapshot[]
  prices                PriceSnapshot[]
  marketCalendars       MarketCalendarSnapshot[]
  checks                SnapshotCheck[]
  rebalanceRuns         RebalanceRun[]
  rebalancePlans        RebalancePlan[]
  rebalancePlanVersions RebalancePlanVersion[]

  @@index([accountId, observedAt(sort: Desc)])
  @@map("portfolio_snapshot")
}

model HoldingSnapshot {
  id                   String @id @default(uuid()) @db.Uuid
  snapshotId           String @map("snapshot_id") @db.Uuid
  marketCountry        String @map("market")
  symbol               String
  name                 String
  currency             String
  quantity             String
  lastPrice            String @map("last_price")
  averagePurchasePrice String @map("average_purchase_price")
  marketValue          String @map("market_value")
  marketValueKrwMinor  BigInt @map("market_value_krw_minor")
  rawPayload           Json   @map("raw_payload") @db.JsonB

  snapshot PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)

  @@unique([snapshotId, marketCountry, symbol], map: "holding_snapshot_snapshot_id_market_symbol_key")
  @@map("holding_snapshot")
}

model BuyingPowerSnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  snapshotId        String   @map("snapshot_id") @db.Uuid
  currency          String
  amount            String
  valueKrwMinor     BigInt   @map("value_krw_minor")
  observedAt        DateTime @map("observed_at") @db.Timestamptz(6)
  valuationEligible Boolean  @default(false) @map("valuation_eligible")

  snapshot PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)

  @@unique([snapshotId, currency])
  @@map("buying_power_snapshot")
}

model PriceSnapshot {
  id                 String    @id @default(uuid()) @db.Uuid
  snapshotId         String    @map("snapshot_id") @db.Uuid
  requestAttemptId   String    @map("request_attempt_id") @db.Uuid
  marketCountry      String    @map("market_country")
  symbol             String
  currency           String
  lastPrice          String    @map("last_price")
  providerObservedAt DateTime? @map("provider_observed_at") @db.Timestamptz(6)
  receivedAt         DateTime  @map("received_at") @db.Timestamptz(6)

  snapshot          PortfolioSnapshot    @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  requestAttempt    BrokerRequestAttempt @relation(fields: [requestAttemptId], references: [id], onDelete: Restrict)
  preSubmitEvidence PreSubmitEvidence[]

  @@unique([snapshotId, marketCountry, symbol], map: "price_snapshot_snapshot_market_symbol_key")
  @@index([requestAttemptId])
  @@map("price_snapshot")
}

model MarketCalendarSnapshot {
  id               String   @id @default(uuid()) @db.Uuid
  snapshotId       String   @map("snapshot_id") @db.Uuid
  requestAttemptId String   @map("request_attempt_id") @db.Uuid
  marketCountry    String   @map("market_country")
  requestedDate    DateTime @map("requested_date") @db.Date
  calendar         Json     @db.JsonB
  calendarSha256   String   @map("calendar_sha256") @db.Char(64)
  receivedAt       DateTime @map("received_at") @db.Timestamptz(6)

  snapshot       PortfolioSnapshot    @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  requestAttempt BrokerRequestAttempt @relation(fields: [requestAttemptId], references: [id], onDelete: Restrict)

  @@unique([snapshotId, marketCountry], map: "market_calendar_snapshot_snapshot_market_key")
  @@index([requestAttemptId])
  @@map("market_calendar_snapshot")
}

model SnapshotCheck {
  id         String       @id @default(uuid()) @db.Uuid
  snapshotId String       @map("snapshot_id") @db.Uuid
  ruleCode   String       @map("rule_code")
  subjectKey String       @default("PORTFOLIO") @map("subject_key")
  outcome    CheckOutcome
  detail     Json         @db.JsonB
  checkedAt  DateTime     @map("checked_at") @db.Timestamptz(6)

  snapshot PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)

  @@unique([snapshotId, ruleCode, subjectKey])
  @@map("snapshot_check")
}

model RuntimeLease {
  key          String   @id
  owner        String   @db.Uuid
  acquiredAt   DateTime @map("acquired_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  fencingToken BigInt   @default(1) @map("fencing_token")

  @@index([expiresAt])
  @@map("runtime_lease")
}

model RebalanceRun {
  id                      String             @id @default(uuid()) @db.Uuid
  accountId               String             @map("account_id") @db.Uuid
  snapshotId              String             @map("snapshot_id") @db.Uuid
  snapshotDigest          String             @map("snapshot_digest") @db.Char(64)
  targetConfigVersionId   String             @map("target_config_version_id") @db.Uuid
  targetConfigContentHash String             @map("target_config_content_hash") @db.Char(64)
  mode                    RebalanceMode
  status                  RebalanceRunStatus @default(RUNNING)
  dedupeKey               String             @unique @map("dedupe_key") @db.Char(64)
  startedAt               DateTime           @map("started_at") @db.Timestamptz(6)
  completedAt             DateTime?          @map("completed_at") @db.Timestamptz(6)
  appVersion              String             @map("app_version")
  policyVersion           String             @map("policy_version")
  errorCode               String?            @map("error_code")

  account             BrokerAccount       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  snapshot            PortfolioSnapshot   @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  targetConfigVersion TargetConfigVersion @relation(fields: [targetConfigVersionId], references: [id], onDelete: Restrict)
  plan                RebalancePlan?

  @@index([accountId, startedAt(sort: Desc)])
  @@index([snapshotId, mode])
  @@map("rebalance_run")
}

model RebalancePlan {
  id                    String              @id @default(uuid()) @db.Uuid
  runId                 String              @unique @map("run_id") @db.Uuid
  snapshotId            String              @map("snapshot_id") @db.Uuid
  targetConfigVersionId String              @map("target_config_version_id") @db.Uuid
  mode                  RebalanceMode
  status                RebalancePlanStatus
  canonicalVersion      String              @map("canonical_version")
  planHash              String              @map("plan_hash") @db.Char(64)
  returnPolicy          String              @map("return_policy")
  totalValueMinor       BigInt?             @map("total_value_minor")
  reasonCodes           Json                @map("reason_codes") @db.JsonB
  canonicalContent      String              @map("canonical_content") @db.Text
  assetDecisions        Json                @map("asset_decisions") @db.JsonB
  deferredBuyNeeds      Json                @map("deferred_buy_needs") @db.JsonB
  projectedAllocations  Json                @map("projected_allocations") @db.JsonB
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  run                   RebalanceRun            @relation(fields: [runId], references: [id], onDelete: Restrict)
  snapshot              PortfolioSnapshot       @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  targetConfigVersion   TargetConfigVersion     @relation(fields: [targetConfigVersionId], references: [id], onDelete: Restrict)
  orders                RebalancePlanOrder[]
  versions              RebalancePlanVersion[]
  ledgerOrders          OrderLedger[]
  executionRiskEvidence ExecutionRiskEvidence[]

  @@unique([snapshotId, targetConfigVersionId, mode, planHash], map: "rebalance_plan_identity_key")
  @@index([createdAt(sort: Desc)])
  @@map("rebalance_plan")
}

model RebalancePlanVersion {
  id                    String              @id @default(uuid()) @db.Uuid
  planId                String              @map("plan_id") @db.Uuid
  version               Int
  phase                 String
  snapshotId            String              @map("snapshot_id") @db.Uuid
  targetConfigVersionId String              @map("target_config_version_id") @db.Uuid
  mode                  RebalanceMode
  status                RebalancePlanStatus
  canonicalVersion      String              @map("canonical_version")
  planHash              String              @map("plan_hash") @db.Char(64)
  canonicalContent      String              @map("canonical_content") @db.Text
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  plan                  RebalancePlan           @relation(fields: [planId], references: [id], onDelete: Restrict)
  snapshot              PortfolioSnapshot       @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  targetConfigVersion   TargetConfigVersion     @relation(fields: [targetConfigVersionId], references: [id], onDelete: Restrict)
  orders                RebalancePlanOrder[]
  ledgerOrders          OrderLedger[]
  executionRiskEvidence ExecutionRiskEvidence[]

  @@unique([planId, version], map: "rebalance_plan_version_plan_version_key")
  @@unique([id, version], map: "rebalance_plan_version_id_version_key")
  @@index([snapshotId, createdAt(sort: Desc)])
  @@map("rebalance_plan_version")
}

model RebalancePlanOrder {
  id               String   @id @default(uuid()) @db.Uuid
  planId           String   @map("plan_id") @db.Uuid
  planVersion      Int      @default(1) @map("plan_version")
  candidateId      String   @map("candidate_id")
  phase            String
  ordinal          Int
  assetClassId     String   @map("asset_class_id")
  instrumentKey    String   @map("instrument_key")
  marketCountry    String   @map("market_country")
  currency         String
  symbol           String
  side             String
  orderType        String   @map("order_type")
  timeInForce      String   @map("time_in_force")
  quantity         BigInt
  limitPriceMinor  BigInt   @map("limit_price_minor")
  notionalMinor    BigInt   @map("notional_minor")
  unallocatedMinor BigInt   @map("unallocated_minor")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  plan              RebalancePlan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  version           RebalancePlanVersion  @relation(fields: [planId, planVersion], references: [planId, version], onDelete: Restrict)
  ledgerOrder       OrderLedger?
  manualApprovals   ManualOrderApproval[]
  preSubmitEvidence PreSubmitEvidence[]

  @@unique([planId, planVersion, candidateId], map: "rebalance_plan_order_plan_version_candidate_key")
  @@unique([planId, planVersion, phase, ordinal], map: "rebalance_plan_order_plan_version_phase_ordinal_key")
  @@map("rebalance_plan_order")
}

model OperationalConfig {
  id        String   @id @default(uuid()) @db.Uuid
  accountId String   @unique(map: "operational_config_account_id_key") @map("account_id") @db.Uuid
