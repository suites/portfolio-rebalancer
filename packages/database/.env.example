# Prisma migration과 runtime은 반드시 서로 다른 PostgreSQL 역할을 사용합니다.
# 운영에서는 DATABASE_URL에 object owner/direct URL을 넣고 engine에는 전달하지 마세요.
DATABASE_URL=postgresql://portfolio:portfolio_local@127.0.0.1:15432/portfolio_rebalancer

# bootstrap이 생성·갱신할 제한 LOGIN 역할의 연결입니다.
DATABASE_RUNTIME_URL=postgresql://portfolio_runtime:portfolio_runtime_local@127.0.0.1:15432/portfolio_rebalancer
DATABASE_RUNTIME_ROLE=portfolio_runtime

# 기존 direct integration 변수는 migration 호환 fallback으로만 유지합니다.
# POSTGRES_URL_NON_POOLING=postgres://MIGRATION_OWNER:PASSWORD@HOST:5432/postgres?sslmode=require
# DATABASE_DIRECT_URL=postgres://MIGRATION_OWNER:PASSWORD@HOST:5432/postgres?sslmode=require
