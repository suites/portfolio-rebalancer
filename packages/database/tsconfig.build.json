{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts", "generated/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
