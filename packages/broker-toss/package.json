{
  "name": "@portfolio-rebalancer/broker-toss",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "sync:openapi": "node scripts/sync-openapi.mjs",
    "check:openapi": "node scripts/sync-openapi.mjs --source openapi/openapi.json --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@portfolio-rebalancer/broker": "workspace:*",
    "@portfolio-rebalancer/domain": "workspace:*",
    "openapi-fetch": "0.17.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
