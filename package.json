{
  "name": "portfolio-rebalancer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:engine-deps": "pnpm --filter @portfolio-rebalancer/domain build && pnpm --filter @portfolio-rebalancer/broker build && pnpm --filter @portfolio-rebalancer/broker-toss build && pnpm --filter @portfolio-rebalancer/contracts build && pnpm --filter @portfolio-rebalancer/database build",
    "check:openapi": "pnpm --filter @portfolio-rebalancer/broker-toss check:openapi",
    "dev": "pnpm --parallel --filter @portfolio-rebalancer/engine --filter @portfolio-rebalancer/web dev",
    "dev:web": "pnpm --filter @portfolio-rebalancer/web dev",
    "dev:engine": "pnpm --filter @portfolio-rebalancer/engine dev",
    "db:generate": "pnpm --filter @portfolio-rebalancer/database db:generate",
    "db:migrate:dev": "pnpm --filter @portfolio-rebalancer/database db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @portfolio-rebalancer/database db:migrate:deploy",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "typecheck": "pnpm -r run typecheck",
    "toss:sync": "pnpm --filter @portfolio-rebalancer/broker-toss sync:openapi",
    "verify": "pnpm format:check && pnpm check:openapi && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.19.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.1.10"
  }
}
