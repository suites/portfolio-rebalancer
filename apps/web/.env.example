ENGINE_INTERNAL_URL=http://127.0.0.1:4100

# engine과 동일한 32자 이상 무작위 값을 설정해야 보호된 콘솔 API를 사용할 수 있습니다.
# 비어 있으면 모든 보호 route가 fail closed 합니다.
# ENGINE_SERVICE_TOKEN=

# 단일 운영자 콘솔 인증. 모두 server-only이며 NEXT_PUBLIC_ 접두사를 사용하지 않습니다.
# 누락되거나 안전 기준을 충족하지 않으면 콘솔 로그인과 모든 위험 동작을 fail closed 합니다.
WEB_OPERATOR_ID=fred
WEB_OPERATOR_PASSWORD=
# openssl rand -base64 48 등으로 32바이트 이상의 무작위 값을 생성하세요.
WEB_OPERATOR_SESSION_SECRET=
# 기본값: 세션 8시간, 위험 동작 최근 재인증 5분
# WEB_OPERATOR_SESSION_TTL_SECONDS=28800
# WEB_OPERATOR_REAUTH_TTL_SECONDS=300
# localhost 평문 HTTP 예제입니다. Production은 코드가 Secure를 강제하며,
# Tailscale/Caddy HTTPS 개발 환경에서도 true로 바꾸세요.
WEB_OPERATOR_SECURE_COOKIE=false
# production/Vercel에서는 필수입니다. 정확한 origin만 쉼표로 지정합니다.
WEB_OPERATOR_ALLOWED_ORIGINS=https://stock.fredly.dev
