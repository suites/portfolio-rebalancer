{
  "name": "@portfolio-rebalancer/engine",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "prebuild": "pnpm -w build:engine-deps",
    "build": "tsc --noEmit",
    "dev": "tsx watch --conditions=development src/main.ts",
    "start": "tsx --conditions=development src/main.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@portfolio-rebalancer/broker-toss": "workspace:*",
    "@portfolio-rebalancer/contracts": "workspace:*",
    "@portfolio-rebalancer/database": "workspace:*",
    "@portfolio-rebalancer/domain": "workspace:*",
    "dotenv": "^17.2.3",
    "fastify": "5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "tsx": "4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
