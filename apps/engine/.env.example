# ACCOUNT_REFERENCE_KEY=
TOSS_EGRESS_ALLOWLIST_CONFIRMED=false

# Vercel에서는 Supabase Integration이 자동 주입하며 DATABASE_URL보다 우선합니다.
# POSTGRES_PRISMA_URL=postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# 로컬 개발용 fallback입니다.
DATABASE_URL=postgresql://portfolio:portfolio_local@127.0.0.1:15432/portfolio_rebalancer

# 로컬에서는 생략할 수 있습니다. Vercel Production에서는 별도 secret을 사용하세요.
