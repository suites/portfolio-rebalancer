TOSSINVEST_CLIENT_ID=
TOSSINVEST_CLIENT_SECRET=
# TOSSINVEST_ACCOUNT_SEQ=
# ACCOUNT_REFERENCE_KEY=
TOSS_EGRESS_ALLOWLIST_CONFIRMED=false

# Engine에는 migration owner URL을 넣지 않습니다. 운영 pooled URL도 별도 제한 역할로 만드세요.
DATABASE_RUNTIME_URL=postgresql://portfolio_runtime:portfolio_runtime_local@127.0.0.1:15432/portfolio_rebalancer

# Web과 동일한 32자 이상 무작위 값을 설정해야 health 외 내부 route를 사용할 수 있습니다.
# 비어 있으면 보호 route는 모두 fail closed 합니다. Vercel Production은 별도 secret을 사용하세요.
# ENGINE_SERVICE_TOKEN=
# CRON_SECRET=
